{
  "name": "@knoten/shared",
  "version": "0.0.0",
  "private": true,
  "description": "Framework-agnostic shared types, Zod schemas and utilities",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "dev": "tsc --build tsconfig.build.json --watch",
    "typecheck": "tsc --build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@knoten/config-eslint": "workspace:*",
    "@knoten/config-typescript": "workspace:*",
    "eslint": "^9.37.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
